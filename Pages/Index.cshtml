@page
@model IndexModel
@{
    ViewData["Title"] = "Wardrobe";
}

<div class="text-center">
    <h1 class="display-4">What are you gonna wear today?</h1>
    <div class="background">
        <img src="/items/1_TShirt_Sport_Blue.jpg" class="itempics"/>
        <img src="/items/Dark_winter_jacket.jpg" class="itempics"/>
        <img src="/items/Fabricair_backpack.jpg" class="itempics" />
    </div>
</div>

<button id="addItemButton" class="genericbutton" onclick="document.getElementById('forNewItem').style.display='flex'">Add New Item</button>

<div id="forNewItem">
    <div id="forNewItemOverlay">
        <h2>Add a new item</h2>
    <form id="newItemForm" method="post">
            <label class="lab">Name: </label> <br>
            <input type="text" class="in" name="Name" required><br>
            <label class="lines">Description: </label> <br>
            <input type="text" class="in" name="Description"><br>
            <label class="lines">Season: </label> <br>
            <input type="text" class="in" name="Season"><br>
            <label class="lines">Arrived: </label> <br>
            <input type="text" class="in" name="Age"><br>
            <br>
            <button type="submit">Save</button>
            <button type="button" onclick="document.getElementById('forNewItem').style.display ='none'">Close</button>
    </form>
    </div>
   </div>

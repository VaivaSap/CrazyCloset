@page
@model PatternsModel
@{
	ViewData["Title"] = "Do you know what you like to wear?";
}
<h1>@ViewData["Title"]</h1>


<h3 style="color: whitesmoke">The most popular ones in 2026</h3>

<div class="background">
	<div id="chartTooltip" style="position: absolute; display: none; background: white; border: 1px solid #ccc; padding: 10px; border-radius: 5px; pointer-events: none; z-index: 1000;">
		<img id="tooltipImage" style="width: 100px; height: 100px; object-fit: cover;" />
		<p id="tooltipText"></p>
	</div>

	<canvas id="popularityChart" width="600" height="300">
	</canvas>
	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

	<script>
        const logs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Logs));
	</script>
	<script src="~/js/patterns.js"></script>
</div>